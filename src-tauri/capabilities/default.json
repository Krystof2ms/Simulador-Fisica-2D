{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "about"
  ],
  "permissions": [
    "core:default",
    "core:app:allow-version",
    "opener:default",
    "dialog:default",
    "fs:write-all",
    "fs:read-all",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-open",
    "store:default",
    "core:window:allow-destroy",
    "core:window:allow-set-focus",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**/*"
        },
        {
          "path": "$DOCUMENT/**/*"
        },
        {
          "path": "$DOWNLOAD/**/*"
        }
      ]
    }
  ]
}
