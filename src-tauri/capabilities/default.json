{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:write-all",
    "fs:read-all",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-open",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**/*"
        },
        {
          "path": "$DOCUMENT/**/*"
        },
        {
          "path": "$DOWNLOAD/**/*"
        }
      ]
    },
    "store:default"
  ]
}