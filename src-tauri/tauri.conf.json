{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "simulador-fisica-2d",
  "version": "0.1.0",
  "identifier": "com.krystof2ms.simulador-fisica-2d",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "simulador-fisica-2d",
        "width": 1300,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 750
      }
    ],
    "security": {
      "csp": null,
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/180x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
